# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_URL=jdbc:postgresql://localhost:5432/crm_backend
DB_USER=postgres
DB_PASSWORD=changeme

# ========================================
# EMAIL CONFIGURATION (SMTP - Brevo/Gmail)
# ========================================
# Para Brevo: smtp-relay.brevo.com:587
# Para Gmail: smtp.gmail.com:587 (requiere App Password)
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=tu_email@ejemplo.com
MAIL_PASSWORD=tu_contraseña_o_token
MAIL_FROM=noreply@crm.com

# ========================================
# WHATSAPP CLOUD API (Meta)
# ========================================
# Obtener desde: https://developers.facebook.com/apps
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=

# ========================================
# APLICACIÓN
# ========================================
# Puerto del servidor (por defecto 8080)
# SERVER_PORT=8080

# Nivel de logging (DEBUG, INFO, WARN, ERROR)
# LOG_LEVEL=INFO
