# ========================================
# FRONTEND ENVIRONMENT CONFIGURATION
# ========================================

# ========================================
# API BACKEND
# ========================================
# URL base del servidor backend (sin trailing slash)
# Ej: http://localhost:8080 (desarrollo)
# Ej: https://api.produccion.com (producción)
VITE_API_URL=http://localhost:8080

# Timeout para peticiones en milisegundos
# VITE_API_TIMEOUT=30000

# ========================================
# DESARROLLO
# ========================================
# Habilitar source maps en construcción de producción
# VITE_SOURCE_MAP=false

# ========================================
# APLICACIÓN
# ========================================
# Título de la aplicación
VITE_APP_TITLE=CRM - Gestión de Contactos y Vendedores
